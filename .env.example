BOT_TOKEN=PASTE_YOUR_BOT_TOKEN_HERE
SUPPORT_USERNAME=@wintoeurope_bot
SUPPORT_URL=https://t.me/win2europe?direct
ADMIN_IDS=123456789

# 0 = use real Marzban, 1 = mock mode
USE_MOCK_MARZBAN=0

# Local DB file
DB_PATH=vpn_bot.db
CHECK_EXPIRED_EVERY_SECONDS=60

# Marzban API
MARZBAN_BASE_URL=http://127.0.0.1:8000
MARZBAN_USERNAME=botadmin
MARZBAN_PASSWORD=PASTE_MARZBAN_PASSWORD_HERE
MARZBAN_VLESS_INBOUND=VLESS TCP REALITY

# Public VPN settings used to build vless:// links
VPN_ADDRESS=vpn.win2europe.xyz
VPN_PORT=443
VPN_SNI=www.microsoft.com
VPN_PUBLIC_KEY=PASTE_REALITY_PUBLIC_KEY_HERE
VPN_SHORT_ID=PASTE_REALITY_SHORT_ID_HERE
VPN_FINGERPRINT=chrome
VPN_ALPN=
VPN_FLOW=xtls-rprx-vision
VPN_SPIDER_X=

